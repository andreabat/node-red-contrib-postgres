{
  "name": "@topcs/node-red-contrib-postgres",
  "version": "2.0.0",
  "scripts": {
    "build": "tsc && cat src/nodes/PostgresDBNode.html src/nodes/PostgresNode.html src/nodes/PostgresListenerNode.html > dist/postgrestor.html && cp src/nodes/*.html dist/",
    "test": "jest --coverage",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "description": "Yet another Node-RED node to query PostgreSQL with query parameters and listening",
  "author": {
    "name": "Andrea Batazzi",
    "email": "andrea.batazzi@gmail.com"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "pg-format": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/andreabat/node-red-contrib-postgres"
  },
  "keywords": [
    "node-red",
    "postgresql",
    "postgres"
  ],
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "postgres": "dist/postgrestor.js"
    },
    "examples": {
      "01-basic-query": "examples/01-basic-query.json",
      "02-named-parameters": "examples/02-named-parameters.json",
      "03-transaction": "examples/03-transaction.json",
      "04-cursor-streaming": "examples/04-cursor-streaming.json",
      "05-copy-export": "examples/05-copy-export.json",
      "06-listener-notify": "examples/06-listener-notify.json",
      "07-retry-transient": "examples/07-retry-transient.json"
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/mustache": "^4.2.0",
    "@types/node": "^22.0.0",
    "@types/node-red-node-test-helper": "^0.3.5",
    "@types/pg": "^8.20.0",
    "@types/pg-format": "^1.0.5",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "node-red": "^5.0.0",
    "node-red-node-test-helper": "^0.3.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "bugs": {
    "url": "https://github.com/andreabat/node-red-contrib-postgres/issues"
  },
  "homepage": "https://github.com/andreabat/node-red-contrib-postgres#readme"
}
